package stringprograms;

public class _39FindMostFrequentCharacter {

	public static void main(String[] args) {
		String s = "abbc";
		int freq = 0;
		char fC = '0';
		for(int i=0; i<s.length(); i++) {
			char ch = s.charAt(i);
			int count=0;
			for(int j=i+1; j<s.length(); j++) {
				if(ch == s.charAt(j))
					count++;
			}
			if(count > freq) {
				freq = count;
				fC = ch;
			}
		}
		
		System.out.println(freq+"->"+fC);
	}
}

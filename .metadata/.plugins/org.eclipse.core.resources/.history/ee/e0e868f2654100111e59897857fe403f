package arrayprograms;

public class _18IntersectionofTwoArrays {

	public static void main(String[] args) {
		int [] a = {1,1,2};
		int [] b = {1,2};
		
		for(int i=0; i<a.length; i++) {
			
			for(int j=0; j<b.length; j++) {
				if(a[i]==b[j]) {
					System.out.println(a[i]);
					break;
				}
			}
		}
	}
}

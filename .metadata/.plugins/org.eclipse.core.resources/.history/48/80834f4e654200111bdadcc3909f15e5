package arrayprograms;

public class _26LongestSubarraywithSumK {

	public static void main(String[] args) {
		int [] a = {1,2,3,1,1,1,1};
		int target = 3;
		
		int length=0;
		for(int i=0; i<a.length; i++) {
			
			int sum=0;
			int len=0;
			for(int j=i; j<a.length; j++) {
				
				sum+=a[j];
				
				if(sum==target) {
					len=j-i;
					if(len>length) {
						length=len;
					}
				}
			}
		}
		System.out.println(length);
	}
}

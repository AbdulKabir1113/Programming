package arrayprograms;

public class _28SmallestSubarraywithGivenSum {

	public static void main(String[] args) {
		int [] a = {2,3,1,2,4,3};
		int target = 7;
		int len = 0;
		
		for(int i=0; i<a.length; i++) {
			int cLen = 0;
			int sum = 0;
			for(int j=i; j<a.length; j++) {
				sum+=a[j];
				
				if(sum==target) {
					len = j-i+1;
					
				     if(len>cLen) {
					    len = cLen;
				}
			}
		}
	  }		
	}
}

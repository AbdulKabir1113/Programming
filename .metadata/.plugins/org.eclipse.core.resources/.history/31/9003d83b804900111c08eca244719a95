package stringprograms;

public class _11RemoveDuplicateCharacters {

	public static void main(String[] args) {
		String s = "aabbcc";
		String res = "";
		for(int i=0; i<s.length(); i++) {
			
			for(int j=i+1; j<s.length(); j++) {
				
				char c = s.charAt(i);
				res+=s.charAt(i);
				if(c==s.charAt(j)) {
					s = s.replace(s.charAt(j), '0');
				}
			}
		}
		System.out.println(res);
	}
}

package arrayprograms;

public class _21FrequencyofElements {

	public static void main(String[] args) {
		int [] a = {1,2,3,2,1,3,3};
		
		for(int i=0; i<a.length; i++) {
			
			boolean isDuplicate = false;
			for(int k=0; k<i; k++) {
				
			                if (a[i] == a[k]) {
			                    isDuplicate = true;
			                    break;
			                }
			            }

			            if (!isDuplicate)
			                System.out.println(a[i]);
			        }

	}
}

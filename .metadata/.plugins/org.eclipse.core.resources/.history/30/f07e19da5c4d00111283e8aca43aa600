package stringprograms;

public class _31CaesarCipher {

	public static void main(String[] args) {
		String s = "TCS 2026";
		int shift = 5;
		StringBuilder res = new StringBuilder();
		
		for(int i=0; i<s.length(); i++) {
			char ch = s.charAt(i);
			
			if( ch>='0' && ch<='9' && ch==' ') {
				res.append(ch);
			}else {
				res.append((char) (ch+3));
			}
		}
		System.out.println(res);
	}
}

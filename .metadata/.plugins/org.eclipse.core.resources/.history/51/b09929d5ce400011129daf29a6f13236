package arrayprograms;

import java.util.Arrays;

public class _12MoveZeros {

	public static void main(String[] args) {
		int [] a = {1,2,0,5,0,17,0,8};
		
		int j=a.length-1;
		for(int i=0; i<a.length; i++) {
              
			if(a[i]==0) {
				if(a[j]!=0) {
					a[j]=a[i];
					j--;
				}
			}
		}
		System.out.println(Arrays.toString(a));
	}
}

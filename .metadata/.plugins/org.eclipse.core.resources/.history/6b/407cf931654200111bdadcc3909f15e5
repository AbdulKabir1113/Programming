package arrayprograms;

public class _25MaximumProductSubarray {

	public static void main(String[] args) {
		int [] a = {1,2,4,6};
		int max = 1;
		
		
		for(int i=0; i<a.length; i++) {
			
			int pro=1;
			for(int j=i; j<a.length; j++) {
				
				pro*= a[j];
				
				

                if (pro > max) {
                    max = pro;
                }
			}
		}
		System.out.println(max);
	}
}

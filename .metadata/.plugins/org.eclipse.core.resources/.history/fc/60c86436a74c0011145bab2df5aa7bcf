package stringprograms;

public class _27CheckifStringContainsOnlyDigits {

	public static void main(String[] args) {
		String s = "123a5";
		
		for(int i=0; i<s.length(); i++) {
			char ch = s.charAt(i);
			
			if(ch>='0' && ch<='9') {
				continue;
			}else {
				System.out.println("NO");
				break;
			}
				
			
		}
	}
}

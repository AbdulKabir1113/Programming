package stringprograms;

public class _23RemoveDuplicatesMaintainingOrder {

	public static void main(String[] args) {
		String s = "banana";
		StringBuilder res = new StringBuilder();
		char [] ch = s.toCharArray();
		
		for(int i=0; i<s.length(); i++) {
			
			for(int j=0; j<i; i++) {
				if(ch[i]!=ch[j]) {
					res.append(ch[i]);
				}
			}
		}
	}
}

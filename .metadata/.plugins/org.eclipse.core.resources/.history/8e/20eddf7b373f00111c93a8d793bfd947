package arrayprograms;

import java.util.Arrays;

public class _5ReverseArray {

	public static void main(String[] args) {
		int [] arr = {1,2,3,4,5};
		
		for(int i=0; i<arr.length; i++) {
			int j=arr.length;
			int temp = arr[i];
			arr[j--] = arr[i];
			arr[i] = temp;
		}
		
		System.out.println(Arrays.toString(arr));
	}
}

package arrayprograms;

public class _42ndLargestElement {

	public static void main(String[] args) {
		int[] arr= {4,3,5,7,8};
		
		int l1 = Integer.MIN_VALUE;
		int l2 = 0;
		
		for(int i=0; i<arr.length; i++) {
			
			if(l1<arr[i] && l2>arr[i]) {
				l1=arr[i];
				l2=l1;
			}
		}
		
		System.out.println(l1);
	}
}
